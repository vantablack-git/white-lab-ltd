# Deployer private key (NEVER commit real keys)
PRIVATE_KEY=your_private_key_without_0x_prefix

# RPC endpoints
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org

# Basescan / Etherscan API (Base uses Etherscan v2)
ETHERSCAN_API_KEY=your_api_key

# Treasury receives transfer-fee share (token feeReceiver)
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# Timelock min delay in seconds (default 48h = 172800)
TIMELOCK_DELAY=172800

# REQUIRED for production deploys (network=base or baseSepolia)
# Must be a 20-byte address and MUST differ from the deployer EOA.
# scripts/deploy.js refuses to leave the deployer with admin authority,
# and on production networks initializes the treasury proxy directly
# onto this address.
MULTISIG_ADDRESS=0x0000000000000000000000000000000000000000

# Cross-chain bridge stub. Skipped on Base mainnet by default.
# Set to "true" only when wiring an audited LayerZero OFT v2.
DEPLOY_OFT=false

# Optional: Firecrawl API for JS-heavy pages + screenshots in White Lab Studio (/studio/)
# Without this key, Studio uses the reader fallback (works for most public docs/blog pages).
FIRECRAWL_API_KEY=

# Optional: purge Cloudflare CDN after deploy (API token needs Cache Purge on zone)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_PURGE_HOSTS=whitelab.ltd,www.whitelab.ltd

# Production deploys ignore this (handover already revokes deployer).
CONFIGURE_DEMO=true
