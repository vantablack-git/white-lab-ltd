{
  "name": "whitelab",
  "version": "1.0.0",
  "description": "WhiteLab Launch OS — $WLAB protocol monorepo",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.js --network hardhat",
    "deploy:local:demo": "hardhat run scripts/deploy.js --network hardhat",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network baseSepolia",
    "deploy:sepolia:demo": "hardhat run scripts/deploy.js --network baseSepolia",
    "configure:demo": "hardhat run scripts/configure-demo-sale.js",
    "handover:multisig": "hardhat run scripts/handover-multisig.js",
    "deploy:base": "hardhat run scripts/deploy.js --network base",
    "build:site": "node scripts/build-static-site.js",
    "start": "node frontend/server.js",
    "preview:site": "npx --yes serve dist -l 4173",
    "verify": "hardhat run scripts/verify.js --network baseSepolia",
    "verify:base": "hardhat run scripts/verify.js --network base",
    "e2e:local": "hardhat run scripts/e2e-local.js --network hardhat",
    "frontend": "npm run start",
    "env:check": "node scripts/validate-env.js",
    "env:check:base": "node scripts/validate-env.js base",
    "validate": "npm run compile && npm test && npm run e2e:local"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@openzeppelin/contracts-upgradeable": "^5.1.0",
    "chai": "^4.5.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.17",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.14"
  }
}
